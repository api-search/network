---
layout: none
---
[
{% for api in site.apis %}
  {
    "name": {{ api.name | jsonify }},
    "description": {{ api.description | strip_html | strip_newlines | jsonify }},
    "tags": {{ api.tags | jsonify }},
    "humanURL": {{ api.humanURL | jsonify }},
    "aid": {{ api.aid | jsonify }},
    "url": "{{ api.url }}"
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
