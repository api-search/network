---
layout: none
---
[
{% assign idx = 0 %}{% for provider in site.providers %}{
"i":{{ idx }},
"type":"provider",
"n":{{ provider.name | jsonify }},
"d":{{ provider.description | strip_html | strip_newlines | truncate: 300 | jsonify }},
"t":{{ provider.tags | jsonify }},
"u":"{{ provider.url }}",
"ac":{{ provider.api_count | default: 0 }},
"cc":{% if provider.capabilities %}{{ provider.capabilities | size }}{% else %}0{% endif %}
}{% assign idx = idx | plus: 1 %},
{% endfor %}{% for api in site.apis %}{
"i":{{ idx }},
"type":"api",
"n":{{ api.name | jsonify }},
"d":{{ api.description | strip_html | strip_newlines | truncate: 300 | jsonify }},
"t":{{ api.tags | jsonify }},
"p":{{ api.provider_name | default: api.provider_slug | jsonify }},
"ps":{{ api.provider_slug | jsonify }},
"h":{{ api.humanURL | jsonify }},
"u":"{{ api.url }}"
}{% assign idx = idx | plus: 1 %}{% unless forloop.last %},{% endunless %}
{% endfor %}{% if site.capabilities.size > 0 %},{% endif %}{% for cap in site.capabilities %}{
"i":{{ idx }},
"type":"capability",
"n":{{ cap.name | jsonify }},
"d":{{ cap.description | strip_html | strip_newlines | truncate: 300 | jsonify }},
"t":{{ cap.tags | jsonify }},
"p":{{ cap.provider_name | default: cap.provider_slug | jsonify }},
"ps":{{ cap.provider_slug | jsonify }},
"u":"{{ cap.url }}",
"st":{{ cap.search_terms | join: ' | ' | truncate: 800 | jsonify }}
}{% assign idx = idx | plus: 1 %}{% unless forloop.last %},{% endunless %}
{% endfor %}{% if site.schemas.size > 0 %},{% endif %}{% for schema in site.schemas %}{
"i":{{ idx }},
"type":"schema",
"n":{{ schema.title | default: schema.name | jsonify }},
"d":{{ schema.description | strip_html | strip_newlines | truncate: 300 | jsonify }},
"t":{{ schema.tags | jsonify }},
"p":{{ schema.provider_name | default: schema.provider_slug | jsonify }},
"ps":{{ schema.provider_slug | jsonify }},
"u":"{{ schema.url }}"
}{% assign idx = idx | plus: 1 %}{% unless forloop.last %},{% endunless %}
{% endfor %}{% if site.asyncapis.size > 0 %},{% endif %}{% for async in site.asyncapis %}{
"i":{{ idx }},
"type":"asyncapi",
"n":{{ async.name | jsonify }},
"d":{{ async.description | strip_html | strip_newlines | truncate: 300 | jsonify }},
"t":{{ async.tags | jsonify }},
"p":{{ async.provider_name | default: async.provider_slug | jsonify }},
"ps":{{ async.provider_slug | jsonify }},
"u":"{{ async.url }}"
}{% assign idx = idx | plus: 1 %}{% unless forloop.last %},{% endunless %}
{% endfor %}{% if site.jsonld.size > 0 %},{% endif %}{% for ld in site.jsonld %}{
"i":{{ idx }},
"type":"jsonld",
"n":{{ ld.name | jsonify }},
"d":{{ ld.description | strip_html | strip_newlines | truncate: 300 | jsonify }},
"t":{{ ld.tags | jsonify }},
"p":{{ ld.provider_name | default: ld.provider_slug | jsonify }},
"ps":{{ ld.provider_slug | jsonify }},
"u":"{{ ld.url }}"
}{% assign idx = idx | plus: 1 %}{% unless forloop.last %},{% endunless %}
{% endfor %}{% if site.rules.size > 0 %},{% endif %}{% for rule in site.rules %}{
"i":{{ idx }},
"type":"rules",
"n":{{ rule.name | jsonify }},
"d":{{ rule.description | strip_html | strip_newlines | truncate: 300 | jsonify }},
"t":{{ rule.tags | jsonify }},
"p":{{ rule.provider_name | default: rule.provider_slug | jsonify }},
"ps":{{ rule.provider_slug | jsonify }},
"u":"{{ rule.url }}"
}{% assign idx = idx | plus: 1 %}{% unless forloop.last %},{% endunless %}
{% endfor %}
]
